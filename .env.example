# ════════════════════════════════════════════════════════════════
# 小酌 · 环境变量模板 (.env.example) —— 这份会进 git，只放「字段名」不放真实值
# 用法：复制为 .env（cp .env.example .env），再把真实值填到每个「=」后面
#       .env 已被 .gitignore 忽略，不会进 git，放心填真实密钥
# 改完保存 → 终端 pnpm dev 重启 → 浏览器 Cmd+Shift+R 硬刷新
# ════════════════════════════════════════════════════════════════
#
# ── ① 出卡必填：大模型 Key（聊天记卡片全靠它，缺了 = 永远不出卡）──────
# 服务端拿它打 LLM 生成卡片。来源：你最初拿到的 forge / Manus 平台 key
# （去 Manus 后台「环境变量 / API Key」处，或你自己的备份 / 密码管理器里找）。
BUILT_IN_FORGE_API_KEY=
#
# 下面几条都是【选填】，不确定就留空走默认：
# · API 网关地址，不填默认 https://forge.manus.im
BUILT_IN_FORGE_API_URL=
# · 模型名，不填默认 gemini-2.5-flash
LLM_MODEL=
# · 想让模型「看懂」喂进来的照片就设 true（你的模型支持图片输入时）
LLM_SUPPORTS_IMAGE=true
# · 是否支持结构化 JSON 输出。留空＝true（「强制出卡」的修复要用它），一般别动
LLM_SUPPORTS_RESPONSE_FORMAT=
#
# ── ② 登录 / 云端保存（只有「打不开工作台」或「想云端存」时才补）────────
# 重启后若卡在登录、进不去工作台，再把这几项填上（值同样去 Manus 后台 / 备份找）：
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=
JWT_SECRET=
# 数据库连接串。不填＝本地用内存 / 本地文件兜底（能跑，但清缓存 / 换机可能丢数据）
DATABASE_URL=
#
# ── ③ 图片生成（喂图出图，302.ai）─────────────────────────────────
# 去 302.ai 后台「API 管理」处拿 key，复制为 .env 后填到下面「=」后面
API302_KEY=
